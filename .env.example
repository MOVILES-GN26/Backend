# ── Environment ──
NODE_ENV=development
PORT=3000

# ── PostgreSQL ──
# Use 'postgres' when running via docker-compose, 'localhost' for local dev
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=andeshub

# ── JWT ── (CHANGE THIS! Use a random string of at least 32 characters)
JWT_SECRET=

# ── MinIO (S3-compatible) ──
# Use 'http://minio:9000' via docker-compose, 'http://localhost:9000' for local dev
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=andeshub

# ── CORS ── (set a specific origin in production)
CORS_ORIGIN=*
